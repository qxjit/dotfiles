#!/usr/bin/env nu

# Open a file in the next pane, blindling assuming that it's helix.
# This would have its own subcommand, but 'bt' won't successfully exec
# the EDITOR as 'dev e'
def main [path: string] {
  zellij action focus-previous-pane
  zellij action write-chars $":e ($path | str replace --all ' ' '\ ')\r"
}

# Spawn or attach to a zellij dev session
def "main t" [] {
  $env.EDITOR = "hx"
  exec zellij attach -c dev
}

# Open go to a zellij tab for a specific project
def "main o" [project: string] {
  let tabs = zellij action query-tab-names

  if ($tabs | lines | any { |it| $it ==  $project }) {
    zellij action go-to-tab-name $project
  } else { 
    let dir = (glob ($env.HOME)/work/*/($project)).0
    cd $dir
    zellij action new-tab --layout ide --name $project
  }
}

# Launch a file tree configured to operate in conjuction with the zellij layout
def "main file-tree" [] {
  $env.EDITOR = "dev"
  exec bt
}
